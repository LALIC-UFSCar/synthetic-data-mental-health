# .env.example
# Copie este arquivo para .env e preencha com suas chaves de API.
# O arquivo .env nunca deve ser commitado no repositório.

# Groq (recomendado — gratuito com limite de 1000 req/dia)
# Crie uma conta em: https://console.groq.com
GROQ_API_KEY=

# OpenAI (opcional)
# Crie uma conta em: https://platform.openai.com
OPENAI_API_KEY=

# MariTalk / Maritaca AI (opcional — boa alternativa para português)
# Crie uma conta em: https://maritaca.ai
MARITALK_API_KEY=
